# ============================================
# AI Agent Builder Lite - 环境变量配置示例
# ============================================

# 应用配置
APP_NAME="AI Agent Builder Lite"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG="true"
LOG_LEVEL="INFO"
LOG_REQUESTS="true"

# 服务器配置
HOST="0.0.0.0"
PORT=8000
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# 数据库配置
DATABASE_URL="postgresql://aiagent:aiagent123@localhost:5432/ai_agent_builder"
POSTGRES_USER="aiagent"
POSTGRES_PASSWORD="aiagent123"
POSTGRES_DB="ai_agent_builder"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432

# Redis配置
REDIS_URL="redis://localhost:6379/0"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# RabbitMQ配置
RABBITMQ_URL="amqp://aiagent:aiagent123@localhost:5672"
RABBITMQ_USER="aiagent"
RABBITMQ_PASSWORD="aiagent123"
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672

# Celery配置
CELERY_BROKER_URL="amqp://aiagent:aiagent123@localhost:5672"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# 安全配置
SECRET_KEY="your-secret-key-here-change-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI模型API密钥
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
DEEPSEEK_API_KEY="your-deepseek-api-key"
MOONSHOT_API_KEY="your-moonshot-api-key"
GOOGLE_API_KEY="your-google-api-key"

# 模型配置
DEFAULT_MODEL="gpt-4-turbo-preview"
FALLBACK_MODEL="gpt-3.5-turbo"
MAX_TOKENS=4096
TEMPERATURE=0.7

# 邮件配置 (可选)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@ai-agent-builder.com"

# 存储配置
STORAGE_TYPE="local"  # local, s3, azure, gcs
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"

# 监控配置
SENTRY_DSN=""
PROMETHEUS_METRICS_PORT=8001

# 前端配置
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
NEXT_PUBLIC_APP_NAME="AI Agent Builder Lite"
NEXT_PUBLIC_GA_TRACKING_ID=""
NEXT_PUBLIC_SENTRY_DSN=""

# 功能开关
FEATURE_AGENT_CREATION="true"
FEATURE_SKILL_MARKET="true"
FEATURE_TEAM_COLLABORATION="false"
FEATURE_BILLING="false"
FEATURE_ANALYTICS="true"

# 限制配置
MAX_AGENTS_PER_USER=10
MAX_SKILLS_PER_AGENT=20
MAX_API_CALLS_PER_DAY=1000
MAX_CONCURRENT_JOBS=5

# 部署配置
DEPLOYMENT_MODE="docker"  # docker, kubernetes, serverless
DOMAIN_NAME="localhost"
SSL_ENABLED="false"

# ============================================
# 开发环境特定配置
# ============================================
if [ "$ENVIRONMENT" = "development" ]; then
    DEBUG="true"
    LOG_LEVEL="DEBUG"
    CORS_ORIGINS="http://localhost:3000,http://localhost:8000,http://localhost:8080"
fi

# ============================================
# 生产环境特定配置
# ============================================
if [ "$ENVIRONMENT" = "production" ]; then
    DEBUG="false"
    LOG_LEVEL="WARNING"
    CORS_ORIGINS="https://your-domain.com"
    SSL_ENABLED="true"
fi